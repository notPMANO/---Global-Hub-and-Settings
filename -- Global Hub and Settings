-- Key system
local ValidKey = "123"
local KeyFilePath = "ProjectDeltaKey.txt"
local KeyValid = false
if isfile and isfile(KeyFilePath) then
    if readfile(KeyFilePath) == ValidKey then KeyValid = true end
end
getgenv().Hub.KeyValid = KeyValid

-- Notification
getgenv().Hub.Notify = function(title, text, duration)
    StarterGui:SetCore("SendNotification", {
        Title = title,
        Text = text,
        Duration = duration or 2,
    })
end

-- Register cleanup
getgenv().Hub.RegisterCleanup = function(func)
    table.insert(getgenv().Hub.CleanupTasks, func)
end

-- Unload function
getgenv().Hub.Unload = function()
    getgenv().Settings.Unloaded = true -- set a flag
    for _, task in ipairs(getgenv().Hub.CleanupTasks) do
        pcall(task)
    end
    pcall(function()
        game:GetService("RunService"):UnbindFromRenderStep("UnifiedAimbot")
    end)
    -- The GUI will be destroyed by a cleanup task added by GUI module
    StarterGui:SetCore("SendNotification", {
        Title = "Project Delta Hub",
        Text = "Hub unloaded successfully!",
        Duration = 3,
    })
end

print("Project Delta Hub Core loaded.")
